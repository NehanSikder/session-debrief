{
  "name": "session-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn a Claude Code session .jsonl into a fast human-readable debrief. In-browser, no server.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
